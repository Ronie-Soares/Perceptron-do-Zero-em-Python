n","perceptron_noise = Perceptron(learning_rate=0.1, n_iterations=100)\n","perceptron_noise.fit(X_noisy, y_and)\n","\n","predictions_noise = perceptron_noise.predict(X_noisy)\n","print(\"Acurácia:\", np.mean(predictions_noise == y_and) * 100)\n","\n","noise_levels = [0.05, 0.1, 0.2, 0.3]\n","\n","# ======================== RESOLVENDO 06 ===================\n","print(\"\\n\" + \"=\"*60)\n","print(\"\"\"\n","6. Implemente uma função de ativação diferente\n"," • Sigmoid: σ(z) = 1 / (1 + e^(-z))\n"," • Compare com step function\n","\"\"\")\n","print(\"-\"*60)\n","\n","def sigmoid(self, z):\n","    return 1 / (1 + np.exp(-z))\n","\n","def predict(self, X):\n","    linear_output = np.dot(X, self.weights) + self.bias\n","    probs = self.sigmoid(linear_output)\n","    return np.where(probs >= 0.5, 1, 0)\n","# ======================== RESOLVENDO 07 ===================\n","print(\"\\n\" + \"=\"*60)\n","print(\"🎯 NÍVEL AVANÇADO\")\n","\n","print(\"\\n\" + \"=\"*60)\n","print(\"\"\"\n","7. Implemente validação cruzada\n"," • Divida dados em treino/teste\n"," • Avalie generalização\n","\"\"\")\n","print(\"-\"*60)\n","\n","from sklearn.model_selection import train_test_split\n","\n","X_train, X_test, y_train, y_test = train_test_split(\n","    X_and, y_and, test_size=0.25, random_state=42\n",")\n","\n","perceptron = Perceptron()\n","perceptron.fit(X_train, y_train)\n","\n","pred = perceptron.predict(X_test)\n","print(\"Acurácia teste:\", np.mean(pred == y_test) * 100)\n","\n","# ======================== RESOLVENDO 08 ===================\n","print(\"\\n\" + \"=\"*60)\n","print(\"\"\"\n","8. Adicione regularização L2\n"," • Penalizar pesos grandes\n"," • w = w - η × λ × w (a cada época)\n","\"\"\")\n","print(\"-\"*60)\n","\n","class Perceptron_regularizacao_L2:\n","  def __init__(self, learning_rate=0.1, n_iterations=100, lambda_l2=0.01):\n","    self.learning_rate = learning_rate\n","    self.n_iterations = n_iterations\n","    self.lambda_l2 = lambda_l2\n","    self.weights = None\n","    self.bias = None\n","    self.errors_history = []\n","\n","  def step_function(self, z):\n","    return np.where(z >= 0, 1, 0)\n","\n","  def predict(self, X):\n","    linear_output = np.dot(X, self.weights) + self.bias\n","    predictions = self.step_function(linear_output)\n","    return predictions\n","\n","  def fit(self, X, y):\n","    n_samples, n_features = X.shape\n","\n","    self.weights = np.zeros(n_features)\n","    self.bias = 0\n","    print(f\"🎯 Iniciando treinamento...\")\n","    print(f\" Pesos iniciais: {self.weights}\")\n","    print(f\" Bias inicial: {self.bias}\")\n","    print(f\" Taxa de aprendizado: {self.learning_rate}\")\n","    print(f\" Número de amostras: {n_samples}\")\n","    print(\"-\" * 50)\n","\n","\n","    for epoch in range(self.n_iterations):\n","      errors = 0\n","\n","      for idx, x_i in enumerate(X):\n","        prediction = self.predict(x_i.reshape(1, -1))[0]\n","        error = y[idx] - prediction\n","\n","        if error != 0:\n","          update = self.learning_rate * error\n","          self.weights += update * x_i\n","          self.weights -= self.learning_rate * self.lambda_l2 * self.weights\n","          self.bias += update\n","          errors += 1\n","\n","      self.errors_history.append(errors)\n","\n","      if (epoch + 1) % 10 == 0:\n","        print(f\"Época {epoch + 1:3d} | Erros: {errors:2d} | \"\n","        f\"Pesos: {self.weights} | Bias: {self.bias:.4f}\")\n","\n","      if errors == 0:\n","        print(f\"\\n✅ Convergência alcançada na época {epoch + 1}!\")\n","        print(f\" Pesos finais: {self.weights}\")\n","        print(f\" Bias final: {self.bias:.4f}\")\n","        break\n","\n","    if errors > 0:\n","      print(f\"\\n⚠ Treinamento finalizado sem convergência completa\")\n","      print(f\" Ainda havia {errors} erros na última época\")\n","\n","    return self\n","# ==================INTANCIANDO CLASSES===============\n","print(\"\\n\" + \"*\"*60)\n","print(\"TREINANDO COM L2\")\n","perceptron_l2 = Perceptron_regularizacao_L2(\n","    learning_rate=0.1,\n","    n_iterations=100,\n","    lambda_l2=0.05\n",")\n","perceptron_l2.fit(X_and, y_and)\n","\n","print(\"\\n\" + \"*\"*60)\n","print(\"TREINANDO COM NORMAL\")\n","perceptron_1 = Perceptron(\n","    learning_rate=0.1,\n","    n_iterations=100\n",")\n","perceptron_1.fit(X_and, y_and)\n","\n","print(\"-\"*60)\n","print(\"COMPARAÇÃO\")\n","print(\"Pesos com L2:\", perceptron_l2.weights)\n","print(\"Bias:\", perceptron_l2.bias)\n","\n","print(\"-\"*60)\n","print(\"Pesos Normal:\", perceptron_1.weights)\n","print(\"Bias:\", perceptron_1.bias)\n","print(\"-\"*60)\n","\n","\n","# ======================== RESOLVENDO 09 ===================\n","print(\"\\n\" + \"=\"*60)\n","print(\"\"\"\n","9. Crie visualização interativa\n"," • Use ipywidgets no Colab\n"," • Sliders para η, número de épocas\n"," • Atualização em tempo real\n","\"\"\")\n","print(\"-\"*60)\n","\n","import ipywidgets as widgets\n","from IPython.display import display, clear_output\n","\n","def train_interactive(lr, epochs, lambda_l2):\n","    clear_output(wait=True)\n","\n","    model = Perceptron_regularizacao_L2(\n","        learning_rate=lr,\n","        n_iterations=epochs,\n","        lambda_l2=lambda_l2\n","    )\n","\n","    model.fit(X_and, y_and)\n","\n","    plot_decision_boundary(\n","        X_and,\n","        y_and,\n","        model,\n","        f\"η={lr} | épocas={epochs} | λ={lambda_l2}\"\n","    )\n","print(\"\\n\" + \"=\"*60)\n","print(\"INTERATIVO PARA PERCEPTRON COM L2\")\n","\n","# Sliders\n","lr_slider = widgets.FloatSlider(\n","    value=0.1,\n","    min=0.01,\n","    max=1.0,\n","    step=0.01,\n","    description=\"Learning Rate\"\n",")\n","\n","epoch_slider = widgets.IntSlider(\n","    value=50,\n","    min=10,\n","    max=200,\n","    step=10,\n","    description=\"Épocas\"\n",")\n","\n","lambda_slider = widgets.FloatSlider(\n","    value=0.01,\n","    min=0.0,\n","    max=0.1,\n","    step=0.005,\n","    description=\"L2 (λ)\"\n",")\n","\n","widgets.interact(\n","    train_interactive,\n","    lr=lr_slider,\n","    epochs=epoch_slider,\n","    lambda_l2=lambda_slider\n",")\n","\n","# ======================== RESOLVENDO 10 ===================\n","print(\"\\n\" + \"=\"*60)\n","print(\"=\"*60)\n","print(\"\"\"\n","10. Pesquise o ADALINE (Adaptive Linear Neuron)\n"," • Diferença para o Perceptron\n"," • Implemente e compare\n","\"\"\")\n","print(\"-\"*60)\n","print(\"\"\"\n","Ambos utilizam entradas, pesos, bias e uma combinação linear.\n","A principal diferença entre eles está na forma como o erro é\n","calculado e utilizado durante o treinamento.\n","\"\"\")\n","class Adaline:\n","    def __init__(self, learning_rate=0.01, n_iterations=100):\n","        self.lr = learning_rate\n","        self.epochs = n_iterations\n","\n","    def fit(self, X, y):\n","        n_features = X.shape[1]\n","        self.w = np.zeros(n_features)\n","        self.b = 0\n","\n","        for _ in range(self.epochs):\n","            for i in range(len(X)):\n","                z = np.dot(X[i], self.w) + self.b\n","                error = y[i] - z\n","                self.w += self.lr * error * X[i]\n","                self.b += self.lr * error\n","\n","adaline = Adaline(\n","    learning_rate=0.1,\n","    n_iterations=100\n",")\n","\n","adaline.fit(X_and, y_and)\n","\n","print(\"-\"*60)\n","print(\"COMPARAÇÃO\")\n","print(\"Pesos com Adaline:\", adaline.w)\n","print(\"Bias com Adaline:\", adaline.b)"],"metadata":{"id":"ZZ-jLwNvp_jz","colab":{"base_uri":"https://localhost:8080/","height":1000,"referenced_widgets":["7c3cba3295db412d90cf34714f3f4d1c","594cf485fa3f483ea18c8f3f597827f1","c053448c7e1d45e5a04281a5ea4b8661","cb2fe0d4fc86430095d4b8b11f23439c","7155040ad67842acb6d57c533c1ebceb","fc1d3110d66f4f689235cc48b7407dcd","e4937ba5a1b7438589b3dcb20d4ad340","0cbbff0c6f464ff9ad80807e641b42f6","e97e6be5866646d6a1b7b1248e1160da","438d1ea285e44464bac5441de1807bd9","f34e41a2d09a4916a3cb2580e7466d9b","